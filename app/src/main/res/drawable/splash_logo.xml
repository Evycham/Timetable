<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Transparent item to lock the intrinsic size of the LayerDrawable to 108dp -->
    <item
        android:width="108dp"
        android:height="108dp">
        <color android:color="@android:color/transparent" />
    </item>

    <!-- The actual logo centered and sized to 76dp -->
    <item
        android:drawable="@drawable/splash_logo_image"
        android:width="76dp"
        android:height="76dp"
        android:gravity="center" />
</layer-list>
